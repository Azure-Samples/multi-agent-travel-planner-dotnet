<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>multi-agent-travel-planner</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Microsoft Agent Framework (1.0 GA family). Verify these versions against
      https://www.nuget.org/packages/Microsoft.Agents.AI before publishing.
    -->
    <PackageReference Include="Microsoft.Agents.AI" Version="1.3.0" />
    <PackageReference Include="Microsoft.Agents.AI.OpenAI" Version="1.3.0" />

    <PackageReference Include="Azure.AI.OpenAI" Version="2.1.0" />
    <PackageReference Include="Azure.Identity" Version="1.13.1" />

    <!-- Azure Monitor OpenTelemetry distro -->
    <PackageReference Include="Azure.Monitor.OpenTelemetry.AspNetCore" Version="1.3.0" />
  </ItemGroup>

</Project>
